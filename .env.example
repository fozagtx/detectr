# Qwen Cloud / DashScope (REQUIRED — live only, no mock/fallback)
DASHSCOPE_API_KEY=sk-xxxxxxxx

# Optional: override models
QWEN_MODEL=qwen3.7-plus
WAN_MODEL=happyhorse-1.1-t2v

# Alibaba Cloud OSS (video storage — proof of Alibaba Cloud usage)
ALIBABA_OSS_REGION=oss-ap-southeast-1
