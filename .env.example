# Required — Qwen Cloud API key
# Token Plan: use sk-sp-… key from Token Plan console (NOT a normal sk- / sk-ws- key)
DASHSCOPE_API_KEY=sk-sp-xxxxxxxx

# Models (optional overrides)
QWEN_MODEL=qwen3.7-plus
WAN_MODEL=happyhorse-1.1-t2v

# Base URL — MUST match your key type:
# Token Plan (OpenAI-compatible):
QWEN_BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# Pay-as-you-go / free tier (will burn free quota, NOT Token Plan credits):
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OSS — only if you upload scene videos
ALIBABA_OSS_REGION=oss-ap-southeast-1
ALIBABA_OSS_BUCKET=detectr-videos
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# Rate limits (per IP, in-memory per instance)
# RATE_LIMIT_ANALYZE=3
# RATE_LIMIT_ANALYZE_WINDOW_MS=900000
# RATE_LIMIT_DETECTIVE=20
# RATE_LIMIT_DETECTIVE_WINDOW_MS=600000
# RATE_LIMIT_DEMO=60
# RATE_LIMIT_DEMO_WINDOW_MS=600000
