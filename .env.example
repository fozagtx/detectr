# Required — live Qwen / DashScope only
DASHSCOPE_API_KEY=sk-xxxxxxxx

# Models (optional overrides)
QWEN_MODEL=qwen3.7-plus
WAN_MODEL=happyhorse-1.1-t2v
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OSS — only if you upload scene videos
ALIBABA_OSS_REGION=oss-ap-southeast-1
ALIBABA_OSS_BUCKET=detectr-videos
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
